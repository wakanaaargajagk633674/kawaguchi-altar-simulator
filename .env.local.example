# このファイルは例です。実値は .env.local に記載し、.env.local はコミットしないこと。

# --- OpenAI Images（高度AI補正 / AI肖像生成 / AIに全てお任せ）---
# サーバー側のみで使用し、クライアントへ絶対に露出しません／ログにも出しません。
# /api/iei-photo/ai-image が OpenAI Images(edits) を呼び出します。
# OPENAI_API_KEY=
# 画像モデル（未設定なら gpt-image-2 を使用）。
# OPENAI_IMAGE_MODEL=gpt-image-2

# --- OpenAI テキスト生成（葬儀司会台本のナレーション生成）---
# /api/funeral-script/generate-narration が OpenAI Responses API を呼び出します。
# 上の OPENAI_API_KEY を共用します（サーバー側のみ／ログに出しません）。
# テキストモデル（未設定なら gpt-5.5 を使用）。本番(Vercel)では OPENAI_TEXT_MODEL=gpt-5.5 を設定。
# OPENAI_TEXT_MODEL=gpt-5.5
