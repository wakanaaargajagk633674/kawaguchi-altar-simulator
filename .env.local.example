# 自前 rembg ワーカー（背景切り抜き）の接続設定
# このファイルは例です。実値は .env.local に記載し、.env.local はコミットしないこと。

# 自前 rembg ワーカーのベースURL。
# ローカルでは localhost より 127.0.0.1 を推奨（環境によっては Node が IPv6(::1) を先に
# 解決し、IPv4 待受のワーカーに繋がらず接続エラーになるため）。
# Local rembg worker. Prefer 127.0.0.1 over localhost to avoid IPv6 resolution issues on some environments.
# 未設定の場合、背景切り抜きは無効になり、UI に未設定エラーを表示します。
REMBG_WORKER_URL=http://127.0.0.1:8000

# rembg ワーカーの認証トークン（任意）。設定するとワーカー側と一致させること。
# サーバー側でのみ使用し、クライアントには露出しません。本番では設定を推奨します。
REMBG_WORKER_TOKEN=

# --- RunPod Serverless（将来の切り替え用。現状は未実装の入口のみ）---
# REMBG_WORKER_URL が未設定で、こちらが設定されている場合に RunPod 経路を使う想定。
# いずれもサーバー側のみで使用し、APIキーはクライアントへ絶対に露出しません。
# RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/<endpoint-id>/runsync
# RUNPOD_API_KEY=

# --- OpenAI Images（高度AI補正 / AI肖像生成 / AIに全てお任せ）---
# サーバー側のみで使用し、クライアントへ絶対に露出しません／ログにも出しません。
# /api/iei-photo/ai-image が OpenAI Images(edits) を呼び出します。
# OPENAI_API_KEY=
# 画像モデル（未設定なら gpt-image-2 を使用）。
# OPENAI_IMAGE_MODEL=gpt-image-2
