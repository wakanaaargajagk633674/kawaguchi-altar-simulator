# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ただし接続設定の雛形は共有するためコミット対象にする
!.env.local.example

# python (rembg worker)
__pycache__/
*.pyc
.venv/

# vercel
.vercel

# 葬儀司会台本: 一時解析用スキャン画像（個人情報を含む。解析後に削除予定・gitに含めない）
/public/images/shikai/
# dev検証ログ
/dev-*.log

# typescript
*.tsbuildinfo
next-env.d.ts
